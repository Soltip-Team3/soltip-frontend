{
  "manifest_version": 3,
  "name": "SolTip",
  "version": "0.1.0",
  "description": "Tip X creators instantly in USDC on Solana",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SolTip"
  }
}
